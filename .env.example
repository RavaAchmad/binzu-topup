# Opsional. Konfigurasi utama sekarang ada di src/config/settings.js.
# Env ini hanya override jika server Anda butuh konfigurasi di luar source code.

# Bot
BOT_NAME=Binzu Topup
BOT_PREFIX=.
LOG_LEVEL=info
OWNER_NUMBERS=6281234567890
OWNER_LIDS=

# Socket debug/hardening override opsional
SOCKET_EVENT_SNIFF=false
SOCKET_IGNORE_STATUS_BROADCAST=true
SOCKET_MAX_MSG_RETRY=5

# WhatsApp session
SESSION_DIR=./sessions/baileys
# Optional untuk login pairing code di server. Isi nomor format E.164 tanpa plus, contoh: 6281234567890
WA_PAIRING_PHONE=

# Storage
DB_FILE=./data/db.json

# Webhook server
PORT=3000
PUBLIC_WEBHOOK_URL=https://domain-anda.com/webhooks/mustika

# MustikaPayment live mode
# Set MUSTIKA_MOCK=false setelah endpoint dan credential valid.
MUSTIKA_MOCK=true
MUSTIKA_BASE_URL=https://api.mustikapayment.example
MUSTIKA_API_KEY=
MUSTIKA_API_SECRET=
MUSTIKA_CREATE_PATH=/transactions
MUSTIKA_STATUS_PATH=/transactions/{invoiceId}
MUSTIKA_SIGNATURE_HEADER=x-mustika-signature
MUSTIKA_WEBHOOK_SECRET=

# Payment behavior
PAYMENT_POLLING_ENABLED=true
PAYMENT_POLL_INTERVAL_MS=30000
INVOICE_TTL_MINUTES=15
ORDER_COOLDOWN_MS=15000

# Mock payment testing
# 0 berarti tidak auto-paid. Gunakan POST /mock/mustika/:invoiceId/pay untuk simulasi bayar.
MOCK_AUTO_PAY_SECONDS=0

# Auto order fulfillment
AUTO_ORDER_MODE=mock
AUTO_ORDER_BASE_URL=
AUTO_ORDER_API_KEY=
AUTO_ORDER_PATH=/orders
AUTO_ORDER_SIMULATED_DELAY_MS=1500
